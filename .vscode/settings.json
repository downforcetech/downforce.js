{
    "editor.renderWhitespace": "trailing",
    "editor.tabSize": 4,
    "editor.trimAutoWhitespace": true,
    "editor.useTabStops": false,
    "editor.wordWrapColumn": 120,
    "files.encoding": "utf8",
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": false,
    "js/ts.format.semicolons": "remove",
    "js/ts.preferences.importModuleSpecifier": "non-relative",
    "js/ts.preferences.importModuleSpecifierEnding": "js",
    "js/ts.preferences.jsxAttributeCompletionStyle": "auto",
    "js/ts.preferences.preferTypeOnlyAutoImports": true,
    "js/ts.preferences.quoteStyle": "single",
    "js/ts.preferences.useAliasesForRenames": false,
    "search.useGlobalIgnoreFiles": true,
    "search.useIgnoreFiles": true,
    "search.useParentIgnoreFiles": true,
}
