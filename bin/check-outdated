#!/usr/bin/env sh

################################################################################
# Checks outdated dependencies.
################################################################################

set -e
set -u

case $(dirname "$0") in
    /*|./*) Dir=$(cd "$(dirname "$0")" && pwd);;
    *) Dir=$(cd "$PWD/$(dirname "$0")" && pwd);;
esac

repo_dir=$(cd "$Dir/.." && pwd)

exec "$Dir/pnpm" outdated -r
