#!/usr/bin/env sh

# USAGE ########################################################################
# clean-git [ <dir> ... ]
################################################################################

set -e
set -u

case $(dirname "$0") in
  /*|./*) Dir=$(cd "$(dirname "$0")" && pwd);;
  *) Dir=$(cd "$PWD/$(dirname "$0")" && pwd);;
esac

repo_dir=$(cd "$Dir/.." && pwd)

if test $# -eq 0; then
  set -- "$repo_dir"
fi

echo '╭─ Cleaning Git ignored files'
for dir; do
  echo "├─ $dir"
  git clean -X -d -f "$dir" | sed -e 's/^/│ /'
done
echo '╰─ ✓ done'
