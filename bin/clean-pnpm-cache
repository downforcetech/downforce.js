#!/usr/bin/env sh

set -e
set -u

case $(dirname "$0") in
  /*|./*) Dir=$(cd "$(dirname "$0")" && pwd);;
  *) Dir=$(cd "$PWD/$(dirname "$0")" && pwd);;
esac

repo_dir=$(cd "$Dir/.." && pwd)

if test $# -eq 0; then
  set -- "$repo_dir"
fi

echo '╭─ Cleaning PNPM state'
for dir; do
  echo "├─ $dir"

  find "$dir" \
    -name '.pnpm-workspace-state-v1.json' \
    -print -exec rm {} + \
  | sed -e 's/^/│ /'
done
echo '╰─ ✓ done'
