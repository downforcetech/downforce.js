#!/usr/bin/env sh

################################################################################
# Bumps up a package version and publishes it.
#
# USAGE
# ./npm-publish version|patch|minor|major <package-dir> ...
#
# EXAMPLE
# ./npm-publish patch ./@downforce/*
################################################################################

set -e # errexit
set -u # nounset

case "$(dirname "$0")" in
    /*|./*) Dir=$(cd "$(dirname "$0")" && pwd);;
    *) Dir=$(cd "$PWD/$(dirname "$0")" && pwd);;
esac

usage() {
    echo
    echo "USAGE: $(basename "$0") --help,-h"
    echo "USAGE: $(basename "$0") version|patch|minor|major <package-dir> ..."
    echo
}

if test $# -lt 2; then
    usage
    exit 1
fi

case $1 in
    --help|-h) shift; usage; exit 0
    ;;
esac

arg_version=$1
shift

for pkg; do
    if test ! -e "$pkg/package.json"; then
        echo "skipping invalid package '$pkg'."
        continue
    fi

    (
        case "$pkg" in
            /*|./*) cd "$pkg";;
            *) cd "$PWD/$pkg";;
        esac

        if test "$arg_version" != version; then
            npm version --no-git-tag-version $arg_version

            printf -- 'Press Enter to continue'
            read answer
        fi

        until npm publish --access public; do
            printf -- 'Press Enter to retry'
            read answer
        done
    )
done
