{
    "name": "@downforce/reactx",
    "version": "1.1.9",
    "type": "module",
    "sideEffects": false,
    "files": [
        "./LICENSE.txt",
        "./**/*.css",
        "./**/*.js",
        "./**/*.d.ts"
    ],
    "exports": {
        "./*": "./*"
    },
    "scripts": {
        "clean": "rm -rf ./.cache/ || true",
        "build": "tsc --project ./tsconfig.json",
        "prepack": "node --run clean && node --run build",
        "preversion": "node --run build"
    },
    "peerDependencies": {
        "@downforce/react": "1",
        "@downforce/std": "1",
        "@downforce/std.css": "1",
        "@downforce/web": "1",
        "@downforce/webx": "1",
        "@types/react": "19",
        "@types/react-dom": "19",
        "react": "19",
        "react-dom": "19"
    },
    "devDependencies": {
        "@downforce/tsconfig": "workspace:*",
        "typescript": "6"
    },
    "author": "Daniele Orlando",
    "license": "MIT",
    "description": "Awesome React UI Widgets",
    "keywords": [
        "React",
        "UI"
    ],
    "homepage": "https://github.com/downforcetech/downforce.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/downforcetech/downforce.js.git"
    },
    "bugs": {
        "url": "https://github.com/downforcetech/downforce.js/issues"
    }
}
