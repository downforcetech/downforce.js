{
    "name": "@downforce/solid",
    "version": "1.1.4",
    "type": "module",
    "sideEffects": false,
    "files": [
        "./LICENSE.txt",
        "./esm/",
        "./ts/"
    ],
    "exports": {
        "./*": "./esm/*.js"
    },
    "scripts": {
        "clean": "rm -rf ./esm/ ./.cache/ || true",
        "build": "babel ./ts/ --out-dir ./esm/ --extensions '.ts,.tsx' --ignore '**/*.d.ts','node_modules/**/*' && tsc --project ./tsconfig.json",
        "prepack": "node --run clean && node --run build",
        "preversion": "node --run build"
    },
    "peerDependencies": {
        "@downforce/std": "1",
        "@downforce/web": "1",
        "solid-js": "1"
    },
    "devDependencies": {
        "@babel/cli": "7",
        "@babel/core": "7",
        "@babel/preset-typescript": "7",
        "@downforce/tsconfig": "workspace:*",
        "babel-preset-solid": "1",
        "typescript": "6"
    },
    "author": "Daniele Orlando",
    "license": "MIT",
    "description": "Awesome Solid",
    "keywords": [
        "Solid"
    ],
    "homepage": "https://github.com/downforcetech/downforce.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/downforcetech/downforce.js.git"
    },
    "bugs": {
        "url": "https://github.com/downforcetech/downforce.js/issues"
    }
}
