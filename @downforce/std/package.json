{
    "name": "@downforce/std",
    "version": "1.3.3",
    "type": "module",
    "sideEffects": false,
    "files": [
        "./LICENSE.txt",
        "./esm/",
        "./ts/"
    ],
    "exports": {
        "./*": "./esm/*.js"
    },
    "scripts": {
        "clean": "rm -rf ./esm/ ./.cache/ || true",
        "build": "tsc --project ./tsconfig.json && tsc --project ./tests/tsconfig.json",
        "test": "node --test --test-reporter ${NODE_TEST_REPORTER:-spec} --enable-source-maps --experimental-transform-types ./tests/**/*.test.ts",
        "prepack": "node --run clean && node --run build && node --run test",
        "preversion": "node --run build && node --run test"
    },
    "devDependencies": {
        "@downforce/tsconfig": "workspace:*",
        "typescript": "6"
    },
    "author": "Daniele Orlando",
    "license": "MIT",
    "description": "Awesome TypeScript and JavaScript",
    "keywords": [
        "TypeScript",
        "JavaScript"
    ],
    "homepage": "https://github.com/downforcetech/downforce.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/downforcetech/downforce.js.git"
    },
    "bugs": {
        "url": "https://github.com/downforcetech/downforce.js/issues"
    }
}
